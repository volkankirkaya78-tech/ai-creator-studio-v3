# Copy this file to .env and paste your key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Optional — default 3000
# PORT=3000

# Google Sign-In (browser): set Web Client ID in js/site-config.js → window.GOOGLE_OAUTH_CLIENT_ID
# (Not an env var — OAuth client IDs for GIS are public; still configure origins in Google Cloud Console.)

# Google token verification on the server (must match the Web Client ID above).
# Used for usage limits + history. Copy the same ID you put in js/site-config.js.
GOOGLE_OAUTH_CLIENT_ID=

# Monthly usage limits (pack generations).
PACK_LIMIT_ANON=3
PACK_LIMIT_FREE=10
PACK_LIMIT_PAID=200

# Comma-separated list of Google `sub` values allowed as "paid" (optional fallback).
PAID_SUBS=
# Optional fallback by email (comma-separated). Keep empty in production;
# real user subscription status should come from webhook storage.
PAID_EMAILS=

# Lemon Squeezy (optional, used for real Pro upgrades)
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_VARIANT_ID_MONTHLY=
LEMONSQUEEZY_WEBHOOK_SIGNING_SECRET=
LEMONSQUEEZY_REDIRECT_URL=

# Optional URL overrides
PUBLIC_BASE_URL=http://localhost:3000
